{
  "expo": {
    "name": "Vulu",
    "slug": "vulu",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#23272A"
    },
    "scheme": [
      "vulu",
      "com.vulustudio.vulu"
    ],
    "ios": {
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "bundleIdentifier": "com.vulustudio.vulu",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Allow microphone access so you can speak in live rooms.",
        "NSCameraUsageDescription": "Allow camera access so you can share video in live rooms."
      }
    },
    "android": {
      "package": "com.vulustudio.vulu",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#23272A"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      "expo-notifications",
      "@config-plugins/react-native-webrtc",
      "expo-audio",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Vulu to access your camera roll so you can choose profile photos.",
          "cameraPermission": "Allow Vulu to access your camera so you can take a selfie.",
          "microphonePermission": false
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
