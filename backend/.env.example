PORT=3000

# JWT verification for the upload signer
AUTH_JWKS_URL=https://issuer.example.com/.well-known/jwks.json
AUTH_JWT_ISSUER=https://issuer.example.com
# Optional but recommended. If set, tokens with a matching `aud` are preferred.
# If your Clerk session template does not emit `aud`, signer falls back to issuer-only verification.
AUTH_JWT_AUDIENCE=vulu-api

# Cloudflare R2 config
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=your_bucket_name
# Public base URL used when saving uploaded asset URLs (R2 custom domain or r2.dev)
R2_PUBLIC_BASE_URL=https://media.your-domain.com
