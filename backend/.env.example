PORT=3000
DATABASE_URL=postgresql://user:password@host:5432/database

# JWT verification for external backend auth (legacy compatibility mode)
AUTH_JWKS_URL=https://issuer.example.com/.well-known/jwks.json
AUTH_JWT_ISSUER=https://issuer.example.com
# Should match the `aud` claim in your backend token.
AUTH_JWT_AUDIENCE=vulu-api
# Set to true only for local debugging without JWT verification.
ALLOW_INSECURE_USER_HEADER_AUTH=false

# Realtime metrics tuning
REALTIME_METRICS_LOG_INTERVAL_MS=60000
REALTIME_LATENCY_SAMPLE_LIMIT=500

# Live presence heartbeat TTL (ms)
LIVE_PRESENCE_TTL_MS=120000

# Cloudflare R2 Config
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=your_bucket_name
# Public base URL used when saving video/audio URLs (R2 custom domain or r2.dev)
R2_PUBLIC_BASE_URL=https://media.your-domain.com
