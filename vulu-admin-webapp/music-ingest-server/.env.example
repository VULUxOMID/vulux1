# Copy to .env (never commit .env). Spotify + R2 credentials required for full functionality.

PORT=3001

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Cloudflare R2 (S3-compatible). Optional override:
# R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# If your bucket is exposed via a custom domain or R2 public URL, uploads will return this:
R2_PUBLIC_BASE_URL=

# List/delete/metadata only under this key prefix (empty = entire bucket).
# Uncomment to restrict to a subfolder instead:
# R2_MUSIC_PREFIX=admin/music/

# Optional: path to yt-dlp binary if not on PATH
# YT_DLP_PATH=/opt/homebrew/bin/yt-dlp
