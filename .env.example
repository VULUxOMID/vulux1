# Copy to .env.local and fill in values. Never commit real secrets.

# Clerk auth
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_or_live_value

# Railway app backend
EXPO_PUBLIC_RAILWAY_API_BASE_URL=http://127.0.0.1:3000
EXPO_PUBLIC_RAILWAY_WS_BASE_URL=ws://127.0.0.1:3000

# Live media/runtime
EXPO_PUBLIC_RTC_ENABLE=1
EXPO_PUBLIC_RTC_DEBUG_OVERLAY=1

# Railway youtube-audio-api (jobs + YouTube Data API proxy). Use the service root only.
EXPO_PUBLIC_YOUTUBE_AUDIO_API_BASE_URL=https://your-youtube-audio-api.up.railway.app

# Optional: only for local dev / direct Google API. Omit in production when using the proxy.
# EXPO_PUBLIC_YOUTUBE_API_KEY=

# Optional YouTube tuning.
# EXPO_PUBLIC_USE_YOUTUBE_PROXY=1
# EXPO_PUBLIC_YOUTUBE_MIN_DURATION_SECONDS=60
# EXPO_PUBLIC_YOUTUBE_MAX_DURATION_SECONDS=419
# EXPO_PUBLIC_YOUTUBE_JOB_POLL_MS=750
# EXPO_PUBLIC_YOUTUBE_JOB_TIMEOUT_MS=300000
# EXPO_PUBLIC_YOUTUBE_ALLOWLIST=
# EXPO_PUBLIC_YOUTUBE_BLOCKLIST=
# EXPO_PUBLIC_YOUTUBE_SEARCH_STRICT_MUSIC=1
# EXPO_PUBLIC_YOUTUBE_FILTER_REGION=1
# EXPO_PUBLIC_VIEWER_REGION_CODE=US
