    "expo-secure-store": "^15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-video": "~3.0.11",
    "expo-video-thumbnails": "~10.0.8",
    "expo-web-browser": "~15.0.8",
    "otplib": "^13.3.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-qrcode-svg": "^6.3.21",
