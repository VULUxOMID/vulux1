{
  "name": "vulu",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "node scripts/build-web.mjs",
    "dev": "CI=1 npx expo start --web --port 5000",
    "test:live-regression": "tsx --test src/data/adapters/backend/liveRepository.regression.test.ts src/features/home/liveNowList.regression.test.ts src/features/live/liveControlEvents.regression.test.ts src/features/live/goLiveStartSubmission.test.ts",
    "test:notifications-regression": "tsx --test src/data/adapters/backend/notificationsRepository.regression.test.ts",
    "test:dm-regression": "tsx --test src/data/adapters/backend/messagesRepository.regression.test.ts",
    "test:event-runtime": "tsx --test src/features/home/widgets/eventRuntimeConfig.test.ts",
    "env:check": "bash ./scripts/env-check.sh",
    "smoke:web:auth": "node --env-file=.env.local scripts/qa/run-authenticated-web-smoke.mjs",
    "railway:deploy:backend": "cd backend && railway up --path-as-root .",
    "railway:migrate:backend": "cd backend && railway ssh npm run migrate"
  },
  "dependencies": {
    "@clerk/clerk-expo": "^2.19.31",
